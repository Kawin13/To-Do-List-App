{
  "name": "taskflow-todo",
  "version": "1.0.0",
  "description": "A production-quality To-Do List app built with Vanilla HTML, CSS, and JavaScript.",
  "main": "index.html",
  "scripts": {
    "start": "npx serve . --listen 8080",
    "dev": "npx live-server --port=8080 --open=/index.html",
    "lint": "npx eslint js/app.js",
    "deploy:gh": "gh-pages -d .",
    "zip": "zip -r taskflow-todo.zip . --exclude='*.git*' --exclude='node_modules/*'"
  },
  "keywords": [
    "todo",
    "vanilla-js",
    "localstorage",
    "html5",
    "css3",
    "javascript",
    "frontend"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "gh-pages": "^6.0.0",
    "live-server": "^1.2.2",
    "serve": "^14.2.3",
    "eslint": "^8.57.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/taskflow-todo.git"
  },
  "homepage": "https://YOUR_USERNAME.github.io/taskflow-todo"
}
